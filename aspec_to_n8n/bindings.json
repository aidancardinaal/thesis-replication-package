    "mock-sheet-messages": {
      "id": "<YOUR_MESSAGES_SHEET_ID>",
      "name": "Messages",
      "url": "https://docs.google.com/spreadsheets/d/<YOUR_MESSAGES_SHEET_ID>/edit"
    },
    "mock-sheet-expenses": {
      "id": "<YOUR_EXPENSES_SHEET_ID>",
      "name": "Expenses",
      "url": "https://docs.google.com/spreadsheets/d/<YOUR_EXPENSES_SHEET_ID>/edit"
    },
    "mock-notion-db-email-tracker": {
      "id": "<YOUR_EMAIL_TRACKER_DB_ID>",
      "name": "Email Tracker",
      "url": "https://www.notion.so/<YOUR_EMAIL_TRACKER_DB_ID>"
    },
    "mock-folder-guidelines": {
      "id": "<YOUR_GUIDELINES_FOLDER_ID>",
      "name": "Guidelines",
      "url": "https://drive.google.com/drive/folders/<YOUR_GUIDELINES_FOLDER_ID>"
    }
  },
  "credentials": {
