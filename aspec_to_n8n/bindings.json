    },
    "mock-cred-notion": {
      "id": "<YOUR_NOTION_CREDENTIAL_ID>",
      "name": "Notion account"
    },
    "mock-cred-google-drive": {
      "id": "<YOUR_GOOGLE_DRIVE_CREDENTIAL_ID>",
      "name": "Google Drive account"
    }
  }
