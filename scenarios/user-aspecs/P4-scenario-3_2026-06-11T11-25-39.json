{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Email new expenses from Google Sheets",
    "description": "I manage expenses in a Google Sheet called Expenses. It has three columns: Expense name, Expense amount, and Expense date. Check the Expenses sheet every minute for new expense rows. Whenever a new expense row is added, write an email from Gmail to expenses@acmecorp.com with the subject \"Expense added\" and a message saying: \"An expense has been added to the expenses sheet. The name is [Expense name], the amount is [Expense amount], and the date is [Expense date].\" The bracketed parts should be automatically replaced with the real values from the new row that was added to the Google Sheet. After sending, label the email that was just sent in Gmail with the label Expenses, which has the label ID Label_expenses.",
    "created_at": "2026-06-11T09:25:39.362740Z",
    "tags": []
  },
  "credentials": {
    "googleSheetsTriggerOAuth2Api": {
      "auth_type": "googleSheetsTriggerOAuth2Api",
      "service": "google_sheets",
      "credential_id": "mock-cred-google-sheets-trigger",
      "status": "ok"
    },
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    }
  },
  "resources": {
    "google_sheets_spreadsheet": {
      "service": "google_sheets",
      "type": "spreadsheet",
      "id": "mock-sheet-expenses",
      "name": "Expenses",
      "details": {
        "sheets": [
          {
            "title": "Sheet1",
            "index": 0,
            "rowCount": 1000,
            "columnCount": 26
          }
        ],
        "columns": [
          "Expense name",
          "Expense amount",
          "Expense date"
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "spreadsheet.trigger.google_sheets",
    "adapter_name": "Google Sheets Trigger",
    "service": "google_sheets",
    "is_trigger": true,
    "configured_parameters": {
      "documentId": "mock-sheet-expenses",
      "sheetName": "Sheet1",
      "event": "rowAdded",
      "pollTimes": "everyMinute"
    },
    "parameter_origin": {
      "documentId": "system",
      "sheetName": "inferred",
      "event": "inferred",
      "pollTimes": "user"
    },
    "credential_ref": "googleSheetsTriggerOAuth2Api",
    "trigger_mode": "polling",
    "outputs": [
      "row_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "email.send.gmail",
      "adapter_name": "Send Email via Gmail",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "emailType": "text",
        "sendTo": "expenses@acmecorp.com",
        "subject": "Expense added",
        "message": "An expense has been added to the expenses sheet. The name is {{row_object.row[\"Expense name\"]}}, the amount is {{row_object.row[\"Expense amount\"]}}, and the date is {{row_object.row[\"Expense date\"]}}."
      },
      "parameter_origin": {
        "emailType": "inferred",
        "sendTo": "user",
        "subject": "user",
        "message": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "send_result"
      ],
      "input_from": "trigger_1"
    },
    {
      "step_id": "step_2",
      "adapter_id": "email.label.gmail",
      "adapter_name": "Add Label to Gmail Message",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "messageId": "{{send_result.messageId}}",
        "labelIds": [
          "[\"Label_expenses\"]"
        ]
      },
      "parameter_origin": {
        "messageId": "user",
        "labelIds": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "label_result"
      ],
      "input_from": "step_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    },
    {
      "from": "step_1",
      "to": "step_2",
      "type": "main"
    }
  ]
}