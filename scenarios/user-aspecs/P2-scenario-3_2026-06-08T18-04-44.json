{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Expense Sheet to Gmail Alert",
    "description": "I have a Google Sheet for my expenses with 3 columns: expense name, expense amount, and expense date. Every 10 minutes, check the sheet for any newly added row. Whenever a new row is found, send an email from Gmail to expenses@acmecorp.com with the subject: expense added. Use the expense name, expense amount, and expense date from the newly added row as the email body, with each value on a separate line. After sending this email, apply the Gmail label expenses, with label ID Label_expenses, to the email that was just sent.",
    "created_at": "2026-06-08T16:04:44.777925Z",
    "tags": []
  },
  "credentials": {
    "googleSheetsTriggerOAuth2Api": {
      "auth_type": "googleSheetsTriggerOAuth2Api",
      "service": "google_sheets",
      "credential_id": "mock-cred-google-sheets-trigger",
      "status": "ok"
    },
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    }
  },
  "resources": {
    "google_sheets_spreadsheet": {
      "service": "google_sheets",
      "type": "spreadsheet",
      "id": "mock-sheet-expenses",
      "name": "Expenses",
      "details": {
        "sheets": [
          {
            "title": "Sheet1",
            "index": 0,
            "rowCount": 1000,
            "columnCount": 26
          }
        ],
        "columns": [
          "Expense name",
          "Expense amount",
          "Expense date"
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "spreadsheet.trigger.google_sheets",
    "adapter_name": "Google Sheets Trigger",
    "service": "google_sheets",
    "is_trigger": true,
    "configured_parameters": {
      "documentId": "mock-sheet-expenses",
      "sheetName": "Sheet1",
      "event": "rowAdded",
      "pollTimes": "custom"
    },
    "parameter_origin": {
      "documentId": "system",
      "sheetName": "inferred",
      "event": "inferred",
      "pollTimes": "user"
    },
    "credential_ref": "googleSheetsTriggerOAuth2Api",
    "trigger_mode": "polling",
    "outputs": [
      "row_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "email.send.gmail",
      "adapter_name": "Send Email via Gmail",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "emailType": "text",
        "sendTo": "expenses@acmecorp.com",
        "subject": "expense added",
        "message": "{{row_object.row['Expense name']}}\n{{row_object.row['Expense amount']}}\n{{row_object.row['Expense date']}}"
      },
      "parameter_origin": {
        "emailType": "inferred",
        "sendTo": "user",
        "subject": "user",
        "message": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "send_result"
      ],
      "input_from": "trigger_1"
    },
    {
      "step_id": "step_2",
      "adapter_id": "email.label.gmail",
      "adapter_name": "Add Label to Gmail Message",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "messageId": "{{send_result.messageId}}",
        "labelIds": [
          "[\"Label_expenses\"]"
        ]
      },
      "parameter_origin": {
        "messageId": "user",
        "labelIds": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "label_result"
      ],
      "input_from": "step_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    },
    {
      "from": "step_1",
      "to": "step_2",
      "type": "main"
    }
  ]
}