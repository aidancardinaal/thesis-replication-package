{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Email finance when a new Guidelines file is added",
    "description": "I have a Google Drive folder called 'Guidelines'. Check it every minute, and whenever a new file is added, send an email to finance@acmecorp.com with the subject 'guideline added' and this message in the body: 'Dear finance department, a new file was added to the guideline folder. Please check whether this is correct. Link to the file: [webViewLink]'. Include a link to the new file only in the message body. The file name is not important to the email.",
    "created_at": "2026-06-11T09:17:36.718528Z",
    "tags": []
  },
  "credentials": {
    "googleDriveOAuth2Api": {
      "auth_type": "googleDriveOAuth2Api",
      "service": "google_drive",
      "credential_id": "mock-cred-google-drive",
      "status": "ok"
    },
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    }
  },
  "resources": {
    "google_drive_folder": {
      "service": "google_drive",
      "type": "folder",
      "id": "mock-folder-guidelines",
      "name": "Guidelines",
      "details": {}
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "file_storage.trigger.google_drive",
    "adapter_name": "Google Drive Trigger",
    "service": "google_drive",
    "is_trigger": true,
    "configured_parameters": {
      "folderToWatch": "mock-folder-guidelines",
      "triggerOn": "specificFolder",
      "event": "fileCreated",
      "pollTimes": "everyMinute"
    },
    "parameter_origin": {
      "folderToWatch": "system",
      "triggerOn": "inferred",
      "event": "inferred",
      "pollTimes": "user"
    },
    "credential_ref": "googleDriveOAuth2Api",
    "trigger_mode": "polling",
    "outputs": [
      "file_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "email.send.gmail",
      "adapter_name": "Send Email via Gmail",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "emailType": "text",
        "sendTo": "finance@acmecorp.com",
        "subject": "guideline added",
        "message": "Dear finance department, a new file was added to the guideline folder. Please check whether this is correct. Link to the file: {{file_object.webViewLink}}"
      },
      "parameter_origin": {
        "emailType": "inferred",
        "sendTo": "user",
        "subject": "user",
        "message": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "send_result"
      ],
      "input_from": "trigger_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    }
  ]
}