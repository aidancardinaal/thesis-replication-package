{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Save Gmail emails with dorpshuis in subject to Messages sheet",
    "description": "I want Gmail to check for new emails every hour, and save each incoming new email I receive in Gmail to a Google spreadsheet called Messages, in the tab Sheet 1, but only if the email has the word dorpshuis in the subject. Each matching new email should be added as a separate row in the message column, with the email\u2019s subject line and full email body added together in that row.",
    "created_at": "2026-06-08T08:05:22.582856Z",
    "tags": []
  },
  "credentials": {
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    },
    "googleSheetsOAuth2Api": {
      "auth_type": "googleSheetsOAuth2Api",
      "service": "google_sheets",
      "credential_id": "mock-cred-google-sheets",
      "status": "ok"
    }
  },
  "resources": {
    "google_sheets_spreadsheet": {
      "service": "google_sheets",
      "type": "spreadsheet",
      "id": "mock-sheet-messages",
      "name": "Messages",
      "details": {
        "sheets": [
          {
            "title": "Sheet1",
            "index": 0,
            "rowCount": 1000,
            "columnCount": 26,
            "columns": [
              "message"
            ]
          }
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "email.trigger.gmail",
    "adapter_name": "Gmail Trigger",
    "service": "gmail",
    "is_trigger": true,
    "configured_parameters": {
      "folder": "inbox",
      "pollTimes": "everyHour",
      "filters": {
        "subject": "dorpshuis"
      }
    },
    "parameter_origin": {
      "folder": "inferred",
      "pollTimes": "user",
      "filters": "user"
    },
    "credential_ref": "gmailOAuth2",
    "trigger_mode": "polling",
    "outputs": [
      "email_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "spreadsheet.append.google_sheets",
      "adapter_name": "Google Sheets Append",
      "service": "google_sheets",
      "is_trigger": false,
      "configured_parameters": {
        "documentId": "mock-sheet-messages",
        "operation": "append",
        "convertFieldsToString": false,
        "sheetName": "Sheet 1",
        "columns": {
          "message": "{{email_object.subject}}\n\n{{email_object.body}}"
        }
      },
      "parameter_origin": {
        "documentId": "system",
        "operation": "inferred",
        "convertFieldsToString": "inferred",
        "sheetName": "user",
        "columns": "user"
      },
      "credential_ref": "googleSheetsOAuth2Api",
      "outputs": [
        "append_result"
      ],
      "input_from": "trigger_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    }
  ]
}