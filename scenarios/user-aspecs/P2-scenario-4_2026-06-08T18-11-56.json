{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Email finance when a new guidelines file is added",
    "description": "I have a Google Drive folder called \"guidelines\". Check the \"guidelines\" folder every hour for new files. Whenever a new file is added to the folder, send an email to finance@acmecorp.com with the subject \"guidline added\" and a message stating that a new file was added to the guidelines folder, including the file name and a link to the file.",
    "created_at": "2026-06-08T16:11:56.808100Z",
    "tags": []
  },
  "credentials": {
    "googleDriveOAuth2Api": {
      "auth_type": "googleDriveOAuth2Api",
      "service": "google_drive",
      "credential_id": "mock-cred-google-drive",
      "status": "ok"
    },
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    }
  },
  "resources": {
    "google_drive_folder": {
      "service": "google_drive",
      "type": "folder",
      "id": "mock-folder-guidelines",
      "name": "Guidelines",
      "details": {}
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "file_storage.trigger.google_drive",
    "adapter_name": "Google Drive Trigger",
    "service": "google_drive",
    "is_trigger": true,
    "configured_parameters": {
      "folderToWatch": "mock-folder-guidelines",
      "triggerOn": "specificFolder",
      "event": "fileCreated",
      "pollTimes": "everyHour"
    },
    "parameter_origin": {
      "folderToWatch": "system",
      "triggerOn": "inferred",
      "event": "inferred",
      "pollTimes": "user"
    },
    "credential_ref": "googleDriveOAuth2Api",
    "trigger_mode": "polling",
    "outputs": [
      "file_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "email.send.gmail",
      "adapter_name": "Send Email via Gmail",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "emailType": "text",
        "sendTo": "finance@acmecorp.com",
        "subject": "guidline added",
        "message": "Link to the file: {{file_object.webViewLink}}."
      },
      "parameter_origin": {
        "emailType": "inferred",
        "sendTo": "user",
        "subject": "user",
        "message": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "send_result"
      ],
      "input_from": "trigger_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    }
  ]
}