{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Save CEO Emails to Notion and Notify Eric",
    "description": "Whenever I receive an email in my Gmail from the address CEO@acmecorp.com, checked every minute, I want to save that email to my Notion database called Email Tracker and title the database item exactly as Mail. I want to store the sender's email address and the full email body. Then I want to send an email from my Gmail account to my colleague eric@fiber.nl with the subject Please respond to customer and the message saying: The CEO of Acmecorp has reached out from the sender's email address. I would like you to respond to them. This email message should include the sender's email address.",
    "created_at": "2026-06-07T18:42:36.567878Z",
    "tags": []
  },
  "credentials": {
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    },
    "notionApi": {
      "auth_type": "notionApi",
      "service": "notion",
      "credential_id": "mock-cred-notion",
      "status": "ok"
    }
  },
  "resources": {
    "notion_database": {
      "service": "notion",
      "type": "database",
      "id": "mock-notion-db-email-tracker",
      "name": "Email Tracker",
      "details": {
        "properties": [
          "Name",
          "Sender",
          "Email Body"
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "email.trigger.gmail",
    "adapter_name": "Gmail Trigger",
    "service": "gmail",
    "is_trigger": true,
    "configured_parameters": {
      "filters": {
        "from": "CEO@acmecorp.com"
      },
      "folder": "inbox",
      "pollTimes": "everyMinute"
    },
    "parameter_origin": {
      "filters": "inferred",
      "folder": "inferred",
      "pollTimes": "user"
    },
    "credential_ref": "gmailOAuth2",
    "trigger_mode": "polling",
    "outputs": [
      "email_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "database.create_record.notion",
      "adapter_name": "Create Notion Database Page",
      "service": "notion",
      "is_trigger": false,
      "configured_parameters": {
        "databaseId": "mock-notion-db-email-tracker",
        "title": "Mail",
        "propertiesUi": {
          "Sender": "{{email_object.from}}",
          "Email Body": "{{email_object.body}}"
        }
      },
      "parameter_origin": {
        "databaseId": "system",
        "title": "user",
        "propertiesUi": "user"
      },
      "credential_ref": "notionApi",
      "outputs": [
        "record_object"
      ],
      "input_from": "trigger_1"
    },
    {
      "step_id": "step_2",
      "adapter_id": "email.send.gmail",
      "adapter_name": "Send Email via Gmail",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "emailType": "text",
        "sendTo": "eric@fiber.nl",
        "subject": "Please respond to customer",
        "message": "The CEO of Acmecorp has reached out from {{email_object.from}}. I would like you to respond to them."
      },
      "parameter_origin": {
        "emailType": "inferred",
        "sendTo": "user",
        "subject": "user",
        "message": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "send_result"
      ],
      "input_from": "step_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    },
    {
      "from": "step_1",
      "to": "step_2",
      "type": "main"
    }
  ]
}