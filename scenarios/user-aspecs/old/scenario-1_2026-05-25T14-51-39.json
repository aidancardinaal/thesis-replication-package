{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Save Gmail Email Bodies to Messages Sheet",
    "description": "I receive emails in Gmail. I want to automatically save the body of every new email, checking every minute, to the Google Spreadsheet called **Messages**, using the **Sheet1** tab. Each new email should be added as a new row, and only the email body should go in the **message** column.",
    "created_at": "2026-05-25T12:51:39.541409Z",
    "tags": []
  },
  "credentials": {
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    },
    "googleSheetsOAuth2Api": {
      "auth_type": "googleSheetsOAuth2Api",
      "service": "google_sheets",
      "credential_id": "mock-cred-google-sheets",
      "status": "ok"
    }
  },
  "resources": {
    "google_sheets_spreadsheet": {
      "service": "google_sheets",
      "type": "spreadsheet",
      "id": "mock-sheet-messages",
      "name": "Messages",
      "details": {
        "sheets": [
          {
            "title": "Sheet1",
            "index": 0,
            "rowCount": 1000,
            "columnCount": 26,
            "columns": [
              "message"
            ]
          }
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "email.trigger.gmail",
    "adapter_name": "Gmail Trigger",
    "service": "gmail",
    "is_trigger": true,
    "configured_parameters": {
      "pollTimes": "everyMinute",
      "filters": {},
      "folder": "inbox"
    },
    "parameter_origin": {
      "pollTimes": "inferred",
      "filters": "inferred",
      "folder": "inferred"
    },
    "credential_ref": "gmailOAuth2",
    "trigger_mode": "polling",
    "outputs": [
      "email_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "spreadsheet.append.google_sheets",
      "adapter_name": "Google Sheets Append",
      "service": "google_sheets",
      "is_trigger": false,
      "configured_parameters": {
        "documentId": "mock-sheet-messages",
        "operation": "append",
        "convertFieldsToString": false,
        "sheetName": "Sheet1",
        "columns": {
          "message": "{{email_object.body}}"
        }
      },
      "parameter_origin": {
        "documentId": "system",
        "operation": "inferred",
        "convertFieldsToString": "inferred",
        "sheetName": "user",
        "columns": "user"
      },
      "credential_ref": "googleSheetsOAuth2Api",
      "outputs": [
        "append_result"
      ],
      "input_from": "trigger_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    }
  ]
}