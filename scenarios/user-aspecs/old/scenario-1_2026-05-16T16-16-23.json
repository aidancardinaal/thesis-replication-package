{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Log New Gmail Emails to Google Sheets",
    "description": "Every minute, when I receive a new email in my Gmail Inbox, add a plain text snippet to the message column in my Google Sheet named Messages in the Sheet1 tab that includes the first 100 characters of the email body.",
    "created_at": "2026-05-16T14:16:23.716808Z",
    "tags": []
  },
  "credentials": {
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    },
    "googleSheetsOAuth2Api": {
      "auth_type": "googleSheetsOAuth2Api",
      "service": "google_sheets",
      "credential_id": "mock-cred-google-sheets",
      "status": "ok"
    }
  },
  "resources": {
    "google_sheets_spreadsheet": {
      "service": "google_sheets",
      "type": "spreadsheet",
      "id": "mock-sheet-messages",
      "name": "Messages",
      "details": {
        "sheets": [
          {
            "title": "Sheet1",
            "index": 0,
            "rowCount": 1000,
            "columnCount": 26,
            "columns": [
              "message"
            ]
          }
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "email.trigger.gmail",
    "adapter_name": "Gmail Trigger",
    "service": "gmail",
    "is_trigger": true,
    "configured_parameters": {
      "pollTimes": "everyMinute",
      "filters": {},
      "folder": "inbox"
    },
    "parameter_origin": {
      "pollTimes": "user",
      "filters": "user",
      "folder": "user"
    },
    "credential_ref": "gmailOAuth2",
    "trigger_mode": "polling",
    "outputs": [
      "email_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "spreadsheet.append.google_sheets",
      "adapter_name": "Google Sheets Append",
      "service": "google_sheets",
      "is_trigger": false,
      "configured_parameters": {
        "documentId": "mock-sheet-messages",
        "operation": "append",
        "sheetName": "Sheet1",
        "columns": {
          "message": "{{email_object.body}}"
        },
        "convertFieldsToString": false
      },
      "parameter_origin": {
        "documentId": "system",
        "operation": "inferred",
        "sheetName": "user",
        "columns": "user",
        "convertFieldsToString": "user"
      },
      "credential_ref": "googleSheetsOAuth2Api",
      "outputs": [
        "append_result"
      ],
      "input_from": "trigger_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    }
  ]
}