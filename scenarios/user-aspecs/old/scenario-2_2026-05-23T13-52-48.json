{
  "aspec_version": "1.0",
  "metadata": {
    "name": "Track CEO Emails and Notify Erik",
    "description": "When I receive an email from ceo@acmecorp.com in Gmail, I want Gmail to check for new emails from that sender every hour, add a new item called Mail to my Notion database called Email Tracker with the sender\u2019s email address and email body, and then send an email from Gmail to erik@fiber.com that says, \"The CEO of Acme Corp {{email adress from notion page}} has reached out. Respond to them!\" with the subject line \"Respond to Customer\" to make sure he takes action.",
    "created_at": "2026-05-23T11:52:47.923909Z",
    "tags": []
  },
  "credentials": {
    "gmailOAuth2": {
      "auth_type": "gmailOAuth2",
      "service": "gmail",
      "credential_id": "mock-cred-gmail",
      "status": "ok"
    },
    "notionApi": {
      "auth_type": "notionApi",
      "service": "notion",
      "credential_id": "mock-cred-notion",
      "status": "ok"
    }
  },
  "resources": {
    "notion_database": {
      "service": "notion",
      "type": "database",
      "id": "mock-notion-db-email-tracker",
      "name": "Email Tracker",
      "details": {
        "properties": [
          "Mail",
          "Sender",
          "Snippet URL"
        ]
      }
    }
  },
  "trigger": {
    "step_id": "trigger_1",
    "adapter_id": "email.trigger.gmail",
    "adapter_name": "Gmail Trigger",
    "service": "gmail",
    "is_trigger": true,
    "configured_parameters": {
      "folder": "inbox",
      "pollTimes": "everyHour",
      "filters": {
        "from": "ceo@acmecorp.com"
      }
    },
    "parameter_origin": {
      "folder": "inferred",
      "pollTimes": "user",
      "filters": "user"
    },
    "credential_ref": "gmailOAuth2",
    "trigger_mode": "polling",
    "outputs": [
      "email_object"
    ]
  },
  "steps": [
    {
      "step_id": "step_1",
      "adapter_id": "database.create_record.notion",
      "adapter_name": "Create Notion Database Page",
      "service": "notion",
      "is_trigger": false,
      "configured_parameters": {
        "databaseId": "mock-notion-db-email-tracker",
        "title": "{{email_object.subject}}",
        "propertiesUi": {
          "Sender": "{{email_object.from}}",
          "Snippet URL": "{{email_object.body}}"
        }
      },
      "parameter_origin": {
        "databaseId": "system",
        "title": "user",
        "propertiesUi": "user"
      },
      "credential_ref": "notionApi",
      "outputs": [
        "record_object"
      ],
      "input_from": "trigger_1"
    },
    {
      "step_id": "step_2",
      "adapter_id": "email.send.gmail",
      "adapter_name": "Send Email via Gmail",
      "service": "gmail",
      "is_trigger": false,
      "configured_parameters": {
        "emailType": "text",
        "sendTo": "erik@fiber.com",
        "subject": "Respond to Customer",
        "message": "The CEO of Acme Corp {{email_object.from}} has reached out. Respond to them!"
      },
      "parameter_origin": {
        "emailType": "inferred",
        "sendTo": "user",
        "subject": "user",
        "message": "user"
      },
      "credential_ref": "gmailOAuth2",
      "outputs": [
        "send_result"
      ],
      "input_from": "step_1"
    }
  ],
  "connections": [
    {
      "from": "trigger_1",
      "to": "step_1",
      "type": "main"
    },
    {
      "from": "step_1",
      "to": "step_2",
      "type": "main"
    }
  ]
}